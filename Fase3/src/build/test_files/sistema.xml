<world>
    <window width="512" height="512" />
    <camera>
        <position x="100" y="50" z="150" />
        <lookAt x="0" y="0" z="0" />
        <up x="0" y="1" z="0" />
        <projection fov="45" near="1" far="1000" />
    </camera>

    <group>

        <!-- SOL -->
        <group>
            <transform>
                <scale x="15" y="15" z="15"/> 
            </transform>
            <models>
                <model file="./output/sphere.3d" />
            </models>
        </group>

        <!-- MERCÚRIO -->
        <group>
            <transform>
                <rotate angle="20" x="0" y="1" z="0"/>
                <translate x="25" y="0" z="0"/>
                <scale x="0.5" y="0.5" z="0.5"/>
            </transform>
            <models>
                <model file="./output/sphere.3d" />
            </models>
        </group>

        <!-- VÉNUS -->
        <group>
            <transform>
                <rotate angle="30" x="0" y="1" z="0"/>
                <translate x="32" y="0" z="0"/>
                <scale x="1" y="1" z="1"/>
            </transform>
            <models>
                <model file="./output/sphere.3d" />
            </models>
        </group>

        <!-- TERRA + LUA -->
        <group>
            <transform>
                <rotate angle="45" x="0" y="1" z="0"/>
                <translate x="40" y="0" z="0"/>
            </transform>

            <group>
                <transform>
                    <scale x="1.5" y="1.5" z="1.5"/>
                </transform>
                <models>
                    <model file="./output/sphere.3d" />
                </models>
            </group>

            <group>
                <transform>
                    <translate x="3" y="0" z="0"/>
                    <scale x="0.4" y="0.4" z="0.4"/>
                </transform>
                <models>
                    <model file="./output/sphere.3d" />
                </models>
            </group>
        </group>

        <!-- MARTE -->
        <group>
            <transform>
                <rotate angle="60" x="0" y="1" z="0"/>
                <translate x="50" y="0" z="0"/>
                <scale x="0.8" y="0.8" z="0.8"/>
            </transform>
            <models>
                <model file="./output/sphere.3d" />
            </models>
        </group>

        <!-- JÚPITER -->
        <group>
            <transform>
                <rotate angle="90" x="0" y="1" z="0"/>
                <translate x="65" y="0" z="0"/>
                <scale x="6" y="6" z="6"/>
            </transform>
            <models>
                <model file="./output/sphere.3d" />
            </models>
        </group>

        <!-- SATURNO + ANÉIS -->
        <group>
            <transform>
                <rotate angle="120" x="0" y="1" z="0"/>
                <translate x="80" y="0" z="0"/>
            </transform>

            <group>
                <transform>
                    <scale x="5" y="5" z="5"/>
                </transform>
                <models>
                    <model file="./output/sphere.3d" />
                </models>
            </group>

            <group>
                <transform>
                    <rotate angle="25" x="1" y="0" z="0"/>
                    <scale x="1" y="1" z="1"/> 
                </transform>
                <models>
                    <model file="./output/ring.3d" />
                </models>
            </group>
        </group>

        <!-- ÚRANO -->
        <group>
            <transform>
                <rotate angle="160" x="0" y="1" z="0"/>
                <translate x="95" y="0" z="0"/>
                <scale x="3.5" y="3.5" z="3.5"/>
            </transform>
            <models>
                <model file="./output/sphere.3d" />
            </models>
        </group>

        <!-- NEPTUNO -->
        <group>
            <transform>
                <rotate angle="200" x="0" y="1" z="0"/>
                <translate x="110" y="0" z="0"/>
                <scale x="3.5" y="3.5" z="3.5"/>
            </transform>
            <models>
                <model file="./output/sphere.3d" />
            </models>
        </group>

    </group>
</world>